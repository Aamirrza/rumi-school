@model SchoolManagement.Domain.Entities.ActiveClassScheduleView
@{
    ViewData["Title"] = "Class Schedule Details";
}

<div class="row justify-content-center">
    <div class="col-md-8 col-lg-6">
        <div class="content-card">
            <div class="card-header-crimson">
                <h5>Class Schedule Info</h5>
                <a asp-action="Index" class="btn btn-sm btn-secondary"><i class="bi bi-arrow-left me-1"></i> Back to List</a>
            </div>
            <div class="card-body-custom">
                <div class="table-responsive">
                    <table class="table table-bordered align-middle">
                        <tbody>
                            <tr>
                                <th class="w-40 bg-light fw-semibold text-muted">Schedule ID</th>
                                <td>@Model.ClassScheduleId</td>
                            </tr>
                            <tr>
                                <th class="bg-light fw-semibold text-muted">Class Name</th>
                                <td class="fw-bold text-primary">@Model.ClassName</td>
                            </tr>
                            <tr>
                                <th class="bg-light fw-semibold text-muted">Division</th>
                                <td class="fw-bold">@Model.DivisionName</td>
                            </tr>
                            <tr>
                                <th class="bg-light fw-semibold text-muted">Academic Year</th>
                                <td>@Model.FinancialYear</td>
                            </tr>
                            <tr>
                                <th class="bg-light fw-semibold text-muted">Class Teacher</th>
                                <td>@(string.IsNullOrEmpty(Model.StaffFullName) ? "Unassigned" : Model.StaffFullName)</td>
                            </tr>
                            <tr>
                                <th class="bg-light fw-semibold text-muted">Max Capacity</th>
                                <td>@Model.MaxCapacity</td>
                            </tr>
                            <tr>
                                <th class="bg-light fw-semibold text-muted">Is Active</th>
                                <td>
                                    @if (Model.IsActive)
                                    {
                                        <span class="badge-active">Active</span>
                                    }
                                    else
                                    {
                                        <span class="badge-inactive">Inactive</span>
                                    }
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>

                <div class="d-flex justify-content-end mt-4">
                    <a asp-action="Edit" asp-route-id="@Model.ClassScheduleId" class="btn btn-primary"><i class="bi bi-pencil-fill me-1"></i> Edit Details</a>
                </div>
            </div>
        </div>
    </div>
</div>
