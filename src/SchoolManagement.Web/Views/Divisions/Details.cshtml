@model SchoolManagement.Domain.Entities.DivisionMaster
@{
    ViewData["Title"] = "Division Details";
}

<div class="row justify-content-center">
    <div class="col-md-8 col-lg-5">
        <div class="content-card">
            <div class="card-header-crimson">
                <h5>Division Info</h5>
                <a asp-action="Index" class="btn btn-sm btn-secondary"><i class="bi bi-arrow-left me-1"></i> Back to List</a>
            </div>
            <div class="card-body-custom">
                <div class="table-responsive">
                    <table class="table table-bordered align-middle">
                        <tbody>
                            <tr>
                                <th class="w-40 bg-light fw-semibold text-muted">ID</th>
                                <td>@Model.DivisionId</td>
                            </tr>
                            <tr>
                                <th class="bg-light fw-semibold text-muted">Division Name</th>
                                <td class="fw-bold text-primary">@Model.DivisionName</td>
                            </tr>
                            <tr>
                                <th class="bg-light fw-semibold text-muted">Is Active</th>
                                <td>
                                    @if (Model.IsActive)
                                    {
                                        <span class="badge-active">Active</span>
                                    }
                                    else
                                    {
                                        <span class="badge-inactive">Inactive</span>
                                    }
                                </td>
                            </tr>
                            <tr>
                                <th class="bg-light fw-semibold text-muted">Created Date</th>
                                <td class="fs-7 text-muted">@Model.CreatedDate.ToString("g") UTC</td>
                            </tr>
                        </tbody>
                    </table>
                </div>

                <div class="d-flex justify-content-end mt-4">
                    <a asp-action="Edit" asp-route-id="@Model.DivisionId" class="btn btn-primary"><i class="bi bi-pencil-fill me-1"></i> Edit Details</a>
                </div>
            </div>
        </div>
    </div>
</div>
