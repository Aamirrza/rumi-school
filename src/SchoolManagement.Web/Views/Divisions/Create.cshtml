@model SchoolManagement.Domain.Entities.DivisionMaster
@{
    ViewData["Title"] = "Add Division";
}

<div class="row justify-content-center">
    <div class="col-md-8 col-lg-5">
        <div class="content-card">
            <div class="card-header-crimson">
                <h5>New Division</h5>
            </div>
            <div class="card-body-custom">
                <form asp-action="Create" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="mb-4">
                        <label asp-for="DivisionName" class="form-label fw-medium">Division Name</label>
                        <input asp-for="DivisionName" class="form-control" placeholder="e.g. A" />
                        <span asp-validation-for="DivisionName" class="text-danger"></span>
                    </div>

                    <div class="d-flex justify-content-end gap-2">
                        <a asp-action="Index" class="btn btn-secondary">Cancel</a>
                        <button type="submit" class="btn btn-primary">Save</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
