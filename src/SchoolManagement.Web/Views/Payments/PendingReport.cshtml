@model IEnumerable<SchoolManagement.Domain.Entities.PendingFeeReportView>
@{
    ViewData["Title"] = "Pending Fees Report";
}

<div class="row mb-4 no-print">
    <div class="col-12 d-flex justify-content-between align-items-center">
        <div>
            <h3 class="fw-bold mb-1">Pending Fees Report</h3>
            <p class="text-muted mb-0">Financial Year: <span class="badge bg-primary">@ViewBag.ActiveFYName</span></p>
        </div>
        <div>
            <button onclick="window.print()" class="btn btn-crimson me-2">
                <i class="bi bi-printer-fill me-1"></i> Print Report
            </button>
            <a asp-action="Index" class="btn btn-outline-secondary">
                <i class="bi bi-arrow-left me-1"></i> Back to Payments
            </a>
        </div>
    </div>
</div>

<!-- Filters Card -->
<div class="content-card mb-4 no-print">
    <div class="card-header-crimson">
        <h5><i class="bi bi-funnel-fill me-2"></i>Filter Outstanding Fees</h5>
    </div>
    <div class="card-body-custom p-4">
        <form method="get" asp-action="PendingReport" class="row g-3 align-items-end">
            <div class="col-md-4">
                <label class="form-label fw-semibold">Class</label>
                <select name="classId" asp-items="ViewBag.Classes" class="form-select">
                    <option value="">-- All Classes --</option>
                </select>
            </div>
            <div class="col-md-4">
                <label class="form-label fw-semibold">Semester</label>
                <select name="semesterId" asp-items="ViewBag.Semesters" class="form-select">
                    <option value="">-- All Semesters --</option>
                </select>
            </div>
            <div class="col-md-4">
                <button type="submit" class="btn btn-primary me-2">
                    <i class="bi bi-filter me-1"></i> Apply Filter
                </button>
                <a asp-action="PendingReport" class="btn btn-outline-secondary">
                    <i class="bi bi-arrow-counterclockwise me-1"></i> Reset
                </a>
            </div>
        </form>
    </div>
</div>

<!-- Print Header (only visible when printing) -->
<div class="d-none d-print-block mb-4">
    <div class="text-center">
        <h2 class="fw-bold m-0">School Management System</h2>
        <h4 class="text-uppercase text-secondary tracking-wide my-1">Outstanding Fees Report</h4>
        <p class="text-muted m-0">Financial Year: @ViewBag.ActiveFYName | Generated on: @DateTime.Now.ToString("dd-MMM-yyyy hh:mm tt")</p>
        <hr class="my-3" />
    </div>
</div>

<!-- Report Table -->
<div class="content-card">
    <div class="card-header-crimson no-print">
        <h5><i class="bi bi-list-stars me-2"></i>Outstanding Fee Students (@Model.Count())</h5>
    </div>
    <div class="card-body-custom p-0">
        @if (Model.Any())
        {
            <div class="table-responsive">
                <table class="table table-custom mb-0" id="pendingReportTable">
                    <thead>
                        <tr>
                            <th>Student</th>
                            <th>GR No</th>
                            <th>Class & Div</th>
                            <th>Roll #</th>
                            <th>Class Teacher</th>
                            <th>Semester</th>
                            <th class="text-end">Expected (₹)</th>
                            <th class="text-end">Paid (₹)</th>
                            <th class="text-end">Balance (₹)</th>
                            <th class="text-center no-print">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="fw-semibold">@item.StudentFullName</td>
                                <td><span class="badge bg-secondary">@item.GrNo</span></td>
                                <td>@item.ClassName - @item.DivisionName</td>
                                <td>@item.RollNo</td>
                                <td class="text-muted">@(string.IsNullOrEmpty(item.StaffName) ? "-" : item.StaffName)</td>
                                <td class="fw-bold text-dark">@item.SemesterName</td>
                                <td class="text-end fw-semibold text-dark">@item.TotalFeeAmount.ToString("N2")</td>
                                <td class="text-end fw-semibold text-success">@item.AmountPaid.ToString("N2")</td>
                                <td class="text-end fw-bold text-danger">@item.RemainingBalance.ToString("N2")</td>
                                <td class="text-center no-print">
                                    <a asp-action="Collect" asp-route-studentId="@item.StudentId" class="btn btn-success btn-sm font-semibold tracking-tight shadow-sm py-1">
                                        <i class="bi bi-cash-coin me-1"></i> Collect Fee
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                    <tfoot>
                        <tr class="fw-bold bg-light">
                            <td colspan="6" class="text-end text-dark">Total Outstanding Summary:</td>
                            <td class="text-end text-dark border-top-double">@Model.Sum(x => x.TotalFeeAmount).ToString("N2")</td>
                            <td class="text-end text-success border-top-double">@Model.Sum(x => x.AmountPaid).ToString("N2")</td>
                            <td class="text-end text-danger border-top-double">@Model.Sum(x => x.RemainingBalance).ToString("N2")</td>
                            <td class="no-print"></td>
                        </tr>
                    </tfoot>
                </table>
            </div>
        }
        else
        {
            <div class="text-center py-5 text-muted">
                <i class="bi bi-check-circle-fill text-success fs-1"></i>
                <h5 class="mt-3 fw-bold text-dark">No Outstanding Fees!</h5>
                <p>All mapped student fees are fully paid for the selected filters.</p>
            </div>
        }
    </div>
</div>

@section Styles {
    <style>
        .border-top-double {
            border-top: 3px double #dee2e6 !important;
        }

        /* Print styles */
        @@media print {
            .no-print, header, footer, .sidebar, .navbar, .btn {
                display: none !important;
            }
            .content-card {
                border: none !important;
                box-shadow: none !important;
            }
            body {
                background-color: white !important;
                color: black !important;
                font-size: 11px;
            }
            table {
                width: 100% !important;
                border-collapse: collapse !important;
            }
            th, td {
                border: 1px solid #c0c0c0 !important;
                padding: 6px 8px !important;
            }
            .card-body-custom {
                padding: 0 !important;
            }
        }
    </style>
}
