@model SchoolManagement.Domain.Entities.ClassMaster
@{
    ViewData["Title"] = "Add Class";
}

<div class="row justify-content-center">
    <div class="col-md-8 col-lg-5">
        <div class="content-card">
            <div class="card-header-crimson">
                <h5>New Class</h5>
            </div>
            <div class="card-body-custom">
                <form asp-action="Create" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="mb-4">
                        <label asp-for="ClassName" class="form-label fw-medium">Class Name</label>
                        <input asp-for="ClassName" class="form-control" placeholder="e.g. Class 1" />
                        <span asp-validation-for="ClassName" class="text-danger"></span>
                    </div>

                    <div class="d-flex justify-content-end gap-2">
                        <a asp-action="Index" class="btn btn-secondary">Cancel</a>
                        <button type="submit" class="btn btn-primary">Save</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
