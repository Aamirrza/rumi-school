@model SchoolManagement.Domain.Entities.FinancialYear
@{
    ViewData["Title"] = "Delete Financial Year";
}

<div class="row justify-content-center">
    <div class="col-md-8 col-lg-6">
        <div class="content-card border-danger">
            <div class="card-header-crimson bg-danger text-white">
                <h5 class="text-white"><i class="bi bi-exclamation-triangle-fill me-2"></i> Confirm Deletion</h5>
            </div>
            <div class="card-body-custom">
                <div class="alert alert-warning border-0">
                    <i class="bi bi-warning-circle-fill me-2"></i> 
                    Are you sure you want to delete this Financial Year? This action will be blocked if there are active class schedules, student admissions, or student mappings linked to it. Remove dependencies first.
                </div>
                
                <h4 class="text-center my-4 fw-bold text-danger">@Model.FinancialYearName</h4>

                <div class="table-responsive mb-4">
                    <table class="table table-bordered">
                        <tbody>
                            <tr>
                                <th class="w-40 bg-light text-muted">Start Date</th>
                                <td>@Model.StartDate.ToString("dd-MMM-yyyy")</td>
                            </tr>
                            <tr>
                                <th class="bg-light text-muted">End Date</th>
                                <td>@Model.EndDate.ToString("dd-MMM-yyyy")</td>
                            </tr>
                        </tbody>
                    </table>
                </div>

                <form asp-action="Delete" method="post">
                    <input type="hidden" asp-for="FinancialYearId" />
                    <div class="d-flex justify-content-end gap-2">
                        <a asp-action="Index" class="btn btn-secondary">Cancel</a>
                        <button type="submit" class="btn btn-danger"><i class="bi bi-trash-fill me-1"></i> Delete Record</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
