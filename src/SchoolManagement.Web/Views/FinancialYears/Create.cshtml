@model SchoolManagement.Domain.Entities.FinancialYear
@{
    ViewData["Title"] = "Add Financial Year";
}

<div class="row justify-content-center">
    <div class="col-md-8 col-lg-6">
        <div class="content-card">
            <div class="card-header-crimson">
                <h5>New Financial Year</h5>
            </div>
            <div class="card-body-custom">
                <form asp-action="Create" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="FinancialYearName" class="form-label fw-medium">Financial Year Name</label>
                        <input asp-for="FinancialYearName" class="form-control" placeholder="e.g. 2026-2027" />
                        <span asp-validation-for="FinancialYearName" class="text-danger"></span>
                        <div class="form-text fs-8">Standard format: YYYY-YYYY (e.g. 2026-2027)</div>
                    </div>

                    <div class="row g-3 mb-3">
                        <div class="col-sm-6">
                            <label asp-for="StartDate" class="form-label fw-medium">Start Date</label>
                            <input asp-for="StartDate" type="date" class="form-control" />
                            <span asp-validation-for="StartDate" class="text-danger"></span>
                        </div>
                        <div class="col-sm-6">
                            <label asp-for="EndDate" class="form-label fw-medium">End Date</label>
                            <input asp-for="EndDate" type="date" class="form-control" />
                            <span asp-validation-for="EndDate" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="mb-4 form-check">
                        <input asp-for="IsCurrent" class="form-check-input" />
                        <label asp-for="IsCurrent" class="form-check-label fw-medium text-dark">Set as Current Financial Year</label>
                        <div class="form-text fs-8">Note: Setting this as current will deactivate all other financial years.</div>
                    </div>

                    <div class="d-flex justify-content-end gap-2">
                        <a asp-action="Index" class="btn btn-secondary">Cancel</a>
                        <button type="submit" class="btn btn-primary">Save</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
