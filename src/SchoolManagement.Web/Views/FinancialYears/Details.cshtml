@model SchoolManagement.Domain.Entities.FinancialYear
@{
    ViewData["Title"] = "Financial Year Details";
}

<div class="row justify-content-center">
    <div class="col-md-8 col-lg-6">
        <div class="content-card">
            <div class="card-header-crimson">
                <h5>Financial Year Info</h5>
                <a asp-action="Index" class="btn btn-sm btn-secondary"><i class="bi bi-arrow-left me-1"></i> Back to List</a>
            </div>
            <div class="card-body-custom">
                <div class="table-responsive">
                    <table class="table table-bordered align-middle">
                        <tbody>
                            <tr>
                                <th class="w-40 bg-light fw-semibold text-muted">ID</th>
                                <td>@Model.FinancialYearId</td>
                            </tr>
                            <tr>
                                <th class="bg-light fw-semibold text-muted">Financial Year</th>
                                <td class="fw-bold text-primary">@Model.FinancialYearName</td>
                            </tr>
                            <tr>
                                <th class="bg-light fw-semibold text-muted">Start Date</th>
                                <td>@Model.StartDate.ToString("dd-MMMM-yyyy")</td>
                            </tr>
                            <tr>
                                <th class="bg-light fw-semibold text-muted">End Date</th>
                                <td>@Model.EndDate.ToString("dd-MMMM-yyyy")</td>
                            </tr>
                            <tr>
                                <th class="bg-light fw-semibold text-muted">Is Current</th>
                                <td>
                                    @if (Model.IsCurrent)
                                    {
                                        <span class="badge-active">Yes (Current)</span>
                                    }
                                    else
                                    {
                                        <span class="badge-inactive">No</span>
                                    }
                                </td>
                            </tr>
                            <tr>
                                <th class="bg-light fw-semibold text-muted">Created Date</th>
                                <td class="fs-7 text-muted">@Model.CreatedDate.ToString("g") UTC</td>
                            </tr>
                            @if (Model.UpdatedDate.HasValue)
                            {
                                <tr>
                                    <th class="bg-light fw-semibold text-muted">Last Updated Date</th>
                                    <td class="fs-7 text-muted">@Model.UpdatedDate.Value.ToString("g") UTC</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <div class="d-flex justify-content-end gap-2 mt-4">
                    <a asp-action="Edit" asp-route-id="@Model.FinancialYearId" class="btn btn-primary"><i class="bi bi-pencil-fill me-1"></i> Edit Details</a>
                </div>
            </div>
        </div>
    </div>
</div>
