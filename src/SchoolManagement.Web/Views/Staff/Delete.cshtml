@model SchoolManagement.Domain.Entities.StaffDetailsView
@{
    ViewData["Title"] = "Delete Staff Profile";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="content-card border-danger">
            <div class="card-header-crimson bg-danger text-white">
                <h5>Confirm Deletion</h5>
            </div>
            <div class="card-body-custom text-center py-4">
                <i class="bi bi-exclamation-triangle-fill text-danger fs-1 mb-3 d-block"></i>
                <p class="fs-5 mb-1">Are you sure you want to delete the staff profile for</p>
                <h4 class="text-primary mb-3">@Model.StaffFullName</h4>
                <p class="text-muted mb-4 small">This action will soft-delete the profile record. It will not be visible on screens, but history will remain intact in AuditLogs.</p>

                <form asp-action="Delete" method="post">
                    <input type="hidden" asp-for="StaffID" />
                    <div class="d-flex justify-content-center gap-2">
                        <a asp-action="Index" class="btn btn-secondary">Cancel</a>
                        <button type="submit" class="btn btn-danger">Confirm Delete</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
